rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- User Profiles ---
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // --- Notes ---
    match /notes/{noteId} {
      // Allow read if note is public OR user is author (or note doesn't exist yet)
      allow read: if resource == null || (
          resource.data.visibility == 'public' || 
          (request.auth != null && request.auth.uid == resource.data.authorId)
      );
      
      allow create: if request.auth != null && 
          request.resource.data.authorId == request.auth.uid;
          
      // Allow update if author OR if it's a public note incrementing viewCount
      allow update: if (request.auth != null && resource.data.authorId == request.auth.uid) ||
          (resource.data.visibility == 'public' && 
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']));
           
      allow delete: if request.auth != null && 
          resource.data.authorId == request.auth.uid;

      // --- Views Subcollection ---
      match /views/{viewId} {
        // Only the note's author can see the list of viewers
        allow read: if request.auth != null && 
            get(/databases/$(database)/documents/notes/$(noteId)).data.authorId == request.auth.uid;
        
        // Anyone can record a view if the note is public
        allow create, update: if get(/databases/$(database)/documents/notes/$(noteId)).data.visibility == 'public';
      }
    }
    
    // --- Global Access Denied by Default ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
